"http": {
    "address": "0.0.0.0",
    "port": "8080"
  },
  "log": {
    "level": "debug"
  },
  "extensions": {
     "sync": {
      "credentialsFile": "",
      "DownloadDir": "/tmp/zot",
      "registries": [
        {
          "urls": [
            "https://{accountID}.dkr.ecr.{region}.amazonaws.com"
          ],
          "onDemand": true,
          "maxRetries": 5,
          "retryDelay": "2m",
          "credentialHelper": "ecr"
        }
      ]
    }
  }
}
